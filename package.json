{
  "name": "视频炼金术：深度阅读",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx server-main.ts",
    "build": "vite build && esbuild server-main.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/server.js",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "test:unit": "node --import tsx --test tests/server/**/*.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "html-to-image": "^1.11.11",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.0",
    "node-mocks-http": "^1.17.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
